{
  "name": "e-bike-rezerwacje",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",

  "main": "main.js",

  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "electron .",
    "dist": "npm run build && electron-builder --publish never"
  },

  "dependencies": {
    "electron-store": "8.2.0",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest"
  },

  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "electron": "latest",
    "electron-builder": "latest"
  },

  "build": {
    "appId": "com.ebike.rezerwacje",
    "productName": "E-Bike Rezerwacje",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}